% references.bib — populated per-study by stages/05-literature-review.md
%
% At minimum, contains:
%   - the studied paper itself
%   - every paper cited in 02-math-deep-dive.md "Connections" / "Related Work"
%   - any paper referenced in 03-opinions.md
%
% Format: standard BibTeX. Use @article for arxiv (with eprint field), @inproceedings
% for conference papers, @misc for blog posts / preprints without journal venues.

@article{example2026,
  author = {Lastname, Firstname and Other, Author},
  title = {Paper Title},
  journal = {arXiv preprint},
  year = {2026},
  eprint = {2605.06241},
  archivePrefix = {arXiv},
  primaryClass = {cs.CL},
  url = {https://arxiv.org/abs/2605.06241}
}
